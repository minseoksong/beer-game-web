# 서버 환경변수 (선택). 실제 사용 시 .env로 복사 후 수정.

# HTTP/WebSocket 포트
PORT=3001

# 실행 모드. 'production'이면 정적 파일 서빙 활성화
NODE_ENV=development

# JSON DB 파일 경로 (기본: server/data.json)
# DB_PATH=/var/lib/beer-game/data.json

# 빌드된 클라이언트 정적 파일 디렉토리 (기본: server/public)
# PUBLIC_DIR=/app/public

# 로그 레벨: trace | debug | info | warn | error
LOG_LEVEL=info
